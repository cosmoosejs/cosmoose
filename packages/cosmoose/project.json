{
  "name": "cosmoose",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/cosmoose/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "compile": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/cosmoose",
        "tsConfig": "packages/cosmoose/tsconfig.lib.json",
        "main": "packages/cosmoose/src/index.ts",
        "rootDir": "packages/cosmoose/src",
        "assets": ["packages/cosmoose/README.md"]
      },
      "dependsOn": ["^build"]
    },
    "build": {
      "dependsOn": ["compile"],
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/cosmoose"],
      "options": {
        "command": "tsc-alias -p packages/cosmoose/tsconfig.lib.json --outDir dist/packages/cosmoose"
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{workspaceRoot}/coverage/packages/cosmoose"],
      "options": {
        "config": "packages/cosmoose/vite.config.ts"
      }
    },
    "test:integration": {
      "executor": "@nx/vitest:test",
      "options": {
        "config": "packages/cosmoose/integration/vitest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/cosmoose/**/*.ts"]
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/packages/cosmoose"
      }
    }
  }
}
